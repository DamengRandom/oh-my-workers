{
  "name": "oh-my-workers",
  "version": "1.1.0",
  "description": "A personal AI agent that automates daily working tasks at workplace, eg: Cronjobs, KPI reporting and etc",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "setup": "pnpm run dev --setup",
    "start": "pnpm run dev --run",
    "cleanup": "pnpm run dev --cleanup",
    "tsc": "pnpm exec tsc --noEmit 2>&1",
    "seed-mock": "node --loader ts-node/esm src/scripts/seed-mock-users.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "oh-my-workers",
    "kpi",
    "daily work diary",
    "cronjobs",
    "automation",
    "AI agent",
    "langchain",
    "typescript",
    "neon",
    "postgresql",
    "personal assistant"
  ],
  "author": "damengrandom",
  "license": "ISC",
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.3.1",
    "langchain": "^1.2.37",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
